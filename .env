# Root development defaults for the monorepo orchestrator.
# The backend loads this file together with api/.env.

DATABASE_URL="postgresql://postgres:riya123@localhost:5432/enterprise_db"
PORT=3000

FRONTEND_URL="http://localhost:3001"
FRONTEND_URLS="http://127.0.0.1:3001"
FRONTEND_ORIGIN="http://localhost:3001"
FRONTEND_ORIGINS="http://127.0.0.1:3001"

REDIS_ENABLED=false

JWT_SECRET="replace-with-secure-shared-secret"
JWT_ACCESS_SECRET="replace-with-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-secure-refresh-secret"
JWT_ISSUER="http://localhost:3000"
JWT_AUDIENCE="enterprise-api"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
NEXT_PUBLIC_NOTIFICATION_WS_URL="http://localhost:3000"