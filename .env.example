# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_db"

# API
PORT=4000

# Frontend CORS (single origin + optional CSV list)
FRONTEND_URL="http://localhost:3001"
FRONTEND_URLS="http://127.0.0.1:3001,http://192.168.1.43:3001"
# Legacy aliases still supported in code: FRONTEND_ORIGIN, FRONTEND_ORIGINS

# JWT
# Fallback chain for access token secret: JWT_ACCESS_SECRET -> JWT_SECRET -> internal default
JWT_SECRET="replace-with-secure-shared-secret"
JWT_ACCESS_SECRET="replace-with-secure-access-secret"
JWT_REFRESH_SECRET="replace-with-secure-refresh-secret"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"
